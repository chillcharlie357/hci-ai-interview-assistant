# Copy this file to .env and fill in local values.
# Do not commit .env.

# LLM 配置
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=

# 可选应用配置
INTERVIEW_FILLER_WORDS=嗯,啊,呃,额,那个,就是
VITE_API_BASE_URL=http://127.0.0.1:9000 
VITE_INTERVIEW_FILLER_WORDS=嗯,啊,呃,额,那个,就是

# 简历解析工具
MINERU_COMMAND=mineru-open-api
MINERU_TIMEOUT_SEC=120

# UV 包管理器配置
UV_DEFAULT_INDEX=https://pypi.tuna.tsinghua.edu.cn/simple

# LiveKit 配置（可选）
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Supabase 配置（用户认证和数据库）
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=

# 数据库连接（Supabase PostgreSQL）
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# 认证开关（开发时设为 false，生产环境设为 true）
VITE_REQUIRE_AUTH=true
REQUIRE_AUTH=true

# 留空时前端用 ws://<host>:8765/；显式覆盖时这里改。
VITE_ASR_WS_URL=ws://127.0.0.1:9100/  
# qwen | webspeech，默认 qwen，连不上会自动降级到 webspeech
VITE_ASR_PROVIDER=qwen
