# ============================================================
# 环境配置文件模板
# 复制此文件为 .env 并填写本地值（.env 不提交到 git）
# ============================================================

# ---- 应用模式 ----
# development: 本地开发 / Docker 开发模式（由 docker-compose.dev.yml 传入 VITE_APP_ENV）
# production:  Docker 生产模式（由 docker-compose.yml 传入 VITE_APP_ENV）
# 本地 pnpm dev 时 Vite 自动识别为 development，无需在此设置

# ---- 前端 ----
# API 地址（Docker 环境或跨域场景使用；本地开发留空，由 Vite proxy 代理）
VITE_API_BASE_URL=
# 语音识别 WebSocket 地址
VITE_ASR_WS_URL=ws://127.0.0.1:9785/
# 语音识别提供方: qwen | webspeech
VITE_ASR_PROVIDER=qwen
# 是否要求登录
VITE_REQUIRE_AUTH=true
# 语气词列表（逗号分隔）
VITE_INTERVIEW_FILLER_WORDS=嗯,啊,呃,额,那个,就是,然后,um,uh,erm
# 后端回答分析降级规则使用；建议与 VITE_INTERVIEW_FILLER_WORDS 保持一致
INTERVIEW_FILLER_WORDS=嗯,啊,呃,额,那个,就是,然后,um,uh,erm

# ---- 服务端口 ----
# 后端端口（默认 8000）
BACKEND_PORT=8000
# 前端端口（默认 5173）
FRONTEND_PORT=5173
# ASR 端口（默认 9785）
ASR_PORT=9785

# ---- LLM 配置 ----
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=

# Qwen3-ASR realtime (通过后端 WebSocket 中转)
DASHSCOPE_API_KEY=
ASR_WS_PORT=8765

# ---- 简历解析 ----
# MinerU API Token（在 https://mineru.net/apiManage/token 获取）
# 配置后使用 Precision API（更快、优先级更高）
# 未配置时自动使用 Agent API 降级（无需 Token，IP 限流）
MINERU_API_TOKEN=
# 解析超时（默认 300 秒，Precision/Agent API 均适用）
MINERU_TIMEOUT_SEC=300
# 旧版 CLI 命令（已弃用，仅当 MINERU_API_TOKEN 未设置且此值非空时使用）
# MINERU_COMMAND=mineru-open-api

# ---- UV 包管理器 ----
UV_DEFAULT_INDEX=https://pypi.tuna.tsinghua.edu.cn/simple

# ---- LiveKit（可选） ----
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ---- Supabase（用户认证和数据库） ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ---- 日志级别 ----
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
VITE_LOG_LEVEL=info         # debug | info | warn | error（不设=info）

# ---- 认证开关 ----
# 后端认证（true 开启用户认证）
REQUIRE_AUTH=true
