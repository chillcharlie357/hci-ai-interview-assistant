# ===== Dev stage (开发模式：热重载) =====
FROM node:22-slim AS dev
WORKDIR /app
RUN corepack enable
COPY frontend/package.json frontend/pnpm-lock.yaml ./
ENV CI=true
RUN pnpm install --ignore-scripts
COPY frontend/ ./
COPY scripts/setup_face_assets.sh /tmp/setup_face_assets.sh
RUN apt-get update \
    && apt-get install -y --no-install-recommends bash ca-certificates curl \
    && update-ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && FRONTEND_DIR=/app bash /tmp/setup_face_assets.sh \
    && rm -f /tmp/setup_face_assets.sh
EXPOSE 5173
CMD ["pnpm", "dev", "--host", "0.0.0.0", "--port", "5173"]


# ===== Build stage (构建静态文件) =====
FROM dev AS builder
ARG VITE_API_BASE_URL=http://127.0.0.1:8000
ARG VITE_ASR_WS_URL=ws://127.0.0.1:9785/
ARG VITE_ASR_PROVIDER=qwen
ARG VITE_LOGIN_REQUIRED=false
ARG VITE_INTERVIEW_FILLER_WORDS=
ARG VITE_APP_ENV=production
RUN VITE_API_BASE_URL="$VITE_API_BASE_URL" \
    VITE_ASR_WS_URL="$VITE_ASR_WS_URL" \
    VITE_ASR_PROVIDER="$VITE_ASR_PROVIDER" \
    VITE_REQUIRE_AUTH="$VITE_LOGIN_REQUIRED" \
    VITE_INTERVIEW_FILLER_WORDS="$VITE_INTERVIEW_FILLER_WORDS" \
    VITE_APP_ENV="$VITE_APP_ENV" \
    pnpm build


# ===== Prod stage (生产模式：nginx 静态服务) =====
FROM nginx:alpine AS prod
COPY --from=builder /app/dist /usr/share/nginx/html
COPY frontend/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 5173
CMD ["nginx", "-g", "daemon off;"]
